<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;900&display=swap');
        
        body { 
            font-family: 'Space Grotesk', sans-serif; 
        }
        
        /* Custom Neobrutalist Background Pattern */
        .dotted-bg {
            background-image: radial-gradient(#000 2px, transparent 2px);
            background-size: 24px 24px;
            background-color: #f8f8f8;
        }

        /* Hollow text effect */
        .text-stroke {
            -webkit-text-stroke: 2px black;
            color: transparent;
        }

        /* Hazard stripes for security theme */
        .hazard-stripes {
            background: repeating-linear-gradient(
                -45deg,
                #facc15,
                #facc15 10px,
                #000000 10px,
                #000000 20px
            );
        }
    </style>
    <title>System Login | UNLEASHED</title>
</head>
<body class="dotted-bg text-black min-h-screen flex items-center justify-center p-8 pt-24 antialiased selection:bg-red-500 selection:text-white overflow-x-hidden relative">

    <div class="fixed top-0 left-0 w-full overflow-hidden bg-black text-red-500 py-2 z-50 border-b-4 border-black">
        <div class="whitespace-nowrap animate-[marquee_15s_linear_infinite] font-bold tracking-[0.2em] uppercase text-xs flex gap-4">
            <span>/// SYSTEM AUTHENTICATION /// SECURE PORTAL /// CREDENTIALS REQUIRED ///</span>
            <span>/// SYSTEM AUTHENTICATION /// SECURE PORTAL /// CREDENTIALS REQUIRED ///</span>
            <span>/// SYSTEM AUTHENTICATION /// SECURE PORTAL ///</span>
        </div>
    </div>

    <div class="relative w-full max-w-lg group mt-8">
        
        <div class="absolute inset-0 bg-red-600 translate-x-4 translate-y-4 border-4 border-black hidden sm:block transition-transform duration-300 group-hover:translate-x-6 group-hover:translate-y-6"></div>
        
        <div class="relative bg-white border-4 border-black p-8 sm:p-12 shadow-[12px_12px_0_0_#000] hover:shadow-[16px_16px_0_0_#000] hover:-translate-y-2 hover:-translate-x-2 transition-all duration-300 z-10 overflow-hidden">
            
            <div class="absolute top-0 left-0 w-full h-3 hazard-stripes border-b-4 border-black"></div>

            <div class="absolute top-8 right-8 bg-yellow-300 border-4 border-black w-16 h-16 rounded-full flex items-center justify-center font-black text-3xl shadow-[4px_4px_0_0_#000] animate-pulse z-20">
                🔒
            </div>

            <div class="mb-10 mt-4">
                <div class="inline-block bg-black text-red-500 px-3 py-1 font-bold text-xs tracking-widest uppercase mb-4 transform -rotate-2 border-2 border-black">
                    Restricted Area
                </div>
                <h1 class="text-6xl sm:text-7xl font-black uppercase tracking-tighter leading-none text-stroke">System<br><span class="text-black">Login</span></h1>
            </div>
            
            <form action="/login" method="POST" class="space-y-8 flex flex-col">
                
                <div class="group/input relative">
                    <label class="absolute -top-3 left-3 bg-white px-2 font-black uppercase text-xs tracking-widest z-10 border-2 border-black group-focus-within/input:bg-blue-600 group-focus-within/input:text-white transition-colors">Identity Hash (Email)</label>
                    <input type="email" name="email" placeholder="IDENTITY@SYSTEM.COM" required class="w-full border-4 border-black bg-gray-50 p-4 font-bold focus:outline-none focus:bg-blue-50 focus:border-black focus:shadow-[4px_4px_0_0_#000] focus:-translate-y-1 focus:-translate-x-1 transition-all uppercase placeholder-gray-300 text-lg">
                </div>
                
                <div class="group/input relative">
                    <label class="absolute -top-3 left-3 bg-white px-2 font-black uppercase text-xs tracking-widest z-10 border-2 border-black group-focus-within/input:bg-blue-600 group-focus-within/input:text-white transition-colors">Passcode</label>
                    <input type="password" name="password" placeholder="••••••••" required class="w-full border-4 border-black bg-gray-50 p-4 font-bold focus:outline-none focus:bg-blue-50 focus:border-black focus:shadow-[4px_4px_0_0_#000] focus:-translate-y-1 focus:-translate-x-1 transition-all uppercase placeholder-gray-300 text-lg">
                </div>
                
                <button type="submit" class="w-full bg-blue-600 text-white font-black uppercase tracking-widest p-5 border-4 border-black shadow-[6px_6px_0_0_#000] hover:bg-black hover:text-white hover:shadow-[10px_10px_0_0_#000] hover:-translate-y-2 hover:-translate-x-2 active:translate-y-2 active:translate-x-2 active:shadow-none transition-all cursor-pointer mt-4 flex justify-between items-center group/btn">
                    <span class="text-xl">Authenticate</span>
                    <svg class="w-8 h-8 transform group-hover/btn:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="4" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </button>
            </form>

            <div class="mt-10 pt-8 border-t-4 border-black text-center relative">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white px-4">
                    <div class="w-8 h-2 bg-black"></div>
                </div>

                <p class="font-bold uppercase tracking-tight text-gray-500 text-sm">No Identity Record Found?</p>
                <a href="/register" class="inline-block mt-3 bg-white text-black font-black uppercase tracking-widest px-6 py-2 border-4 border-black hover:bg-yellow-300 hover:-translate-y-1 shadow-[4px_4px_0_0_#000] active:translate-y-1 active:shadow-none transition-all">
                    Register Now
                </a>
            </div>
        </div>
    </div>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    keyframes: {
                        marquee: {
                            '0%': { transform: 'translateX(0%)' },
                            '100%': { transform: 'translateX(-50%)' },
                        }
                    }
                }
            }
        }
    </script>
</body>
</html>