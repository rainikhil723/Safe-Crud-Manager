<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TARGET LOCKED</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');

        body {
            font-family: 'VT323', monospace;
            background-color: #000;
            overflow: hidden;
            cursor: crosshair;
        }

        @keyframes strobe {
            0%, 49% { background-color: rgba(255, 0, 0, 0.2); }
            50%, 100% { background-color: rgba(0, 0, 255, 0.2); }
        }

        .police-lights {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            animation: strobe 0.3s infinite;
            pointer-events: none;
            z-index: 10;
        }

        @keyframes spinTarget {
            0% { transform: translate(-50%, -50%) rotate(0deg); }
            100% { transform: translate(-50%, -50%) rotate(360deg); }
        }

        @keyframes pulseTarget {
            0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.8; }
            50% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
        }

        .crosshair {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 400px;
            height: 400px;
            border: 4px solid #ff003c;
            border-radius: 50%;
            transform: translate(-50%, -50%);
            animation: pulseTarget 1s infinite;
            pointer-events: none;
            z-index: 20;
            box-shadow: 0 0 50px #ff003c, inset 0 0 50px #ff003c;
        }

        .crosshair::before, .crosshair::after {
            content: '';
            position: absolute;
            background: #ff003c;
            box-shadow: 0 0 10px #ff003c;
        }

        .crosshair::before {
            top: 50%; left: -20px; right: -20px; height: 2px;
            transform: translateY(-50%);
        }

        .crosshair::after {
            left: 50%; top: -20px; bottom: -20px; width: 2px;
            transform: translateX(-50%);
        }

        .crosshair-spin {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 300px;
            height: 300px;
            border: 2px dashed #ff003c;
            border-radius: 50%;
            animation: spinTarget 4s linear infinite;
            pointer-events: none;
            z-index: 21;
        }

        #laser-dot {
            position: absolute;
            width: 12px;
            height: 12px;
            background-color: #fff;
            border-radius: 50%;
            box-shadow: 0 0 20px 10px #ff003c;
            pointer-events: none;
            z-index: 50;
            transition: all 0.05s ease-out;
            transform: translate(-50%, -50%);
        }

        .crt-overlay {
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            background-size: 100% 4px, 6px 100%;
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            pointer-events: none;
            z-index: 30;
        }

        .terminal {
            background: rgba(0, 0, 0, 0.85);
            border: 1px solid #ff003c;
            box-shadow: 0 0 30px rgba(255, 0, 60, 0.5);
            position: relative;
            z-index: 40;
        }
    </style>
</head>
<body class="text-red-500 h-screen w-screen flex flex-col items-center justify-center p-4">

    <div class="police-lights"></div>
    <div class="crt-overlay"></div>
    
    <div class="crosshair"></div>
    <div class="crosshair-spin"></div>
    
    <div id="laser-dot"></div>

    <div class="absolute top-10 w-full text-center z-40 animate-pulse">
        <h1 class="text-7xl font-bold text-red-600 tracking-widest uppercase drop-shadow-[0_0_20px_#ff003c]">
            LETHAL FORCE AUTHORIZED
        </h1>
        <p class="text-3xl text-yellow-400 mt-4 tracking-widest font-black bg-black/50 inline-block px-6 py-2 border border-yellow-500">
            DO NOT MOVE. TARGET LOCKED.
        </p>
    </div>

    <div class="terminal w-full max-w-4xl h-96 p-8 overflow-hidden flex flex-col justify-end mt-32">
        <div id="terminal-content" class="text-3xl leading-relaxed font-bold tracking-wider"></div>
        <span class="animate-ping text-4xl inline-block w-4 h-8 bg-red-500 mt-2"></span>
    </div>

    <script>
        const laser = document.getElementById('laser-dot');
        
        document.addEventListener('mousemove', (e) => {
            laser.style.left = e.clientX + 'px';
            laser.style.top = e.clientY + 'px';
        });

        const commands = [
            "> INITIATING TRACE PROTOCOL...",
            "> IP ADDRESS PINPOINTED: 192.168.NO.HOPE",
            "> BYPASSING FIREWALLS...",
            "> ACCESSING WEBCAM...",
            "> UPLOADING 'INCCOGNITO' BROWSER HISTORY TO ALL CONTACTS...",
            "> SENDING DATA TO: MOM",
            "> SENDING DATA TO: BOSS",
            "> DEPLOYING CYBER-SWAT TEAM...",
            "> ETA: 14 SECONDS",
            "> PREPARE TO BE DELETED."
        ];

        const terminalContent = document.getElementById('terminal-content');
        let commandIndex = 0;
        let charIndex = 0;

        function typeWriter() {
            if (commandIndex < commands.length) {
                if (charIndex === 0) {
                    const p = document.createElement('p');
                    p.id = 'line-' + commandIndex;
                    p.className = 'mb-2 opacity-0 transition-opacity duration-300';
                    terminalContent.appendChild(p);
                    
                    setTimeout(() => {
                        document.getElementById('line-' + commandIndex).classList.remove('opacity-0');
                    }, 50);
                }

                const currentLine = document.getElementById('line-' + commandIndex);
                
                if (charIndex < commands[commandIndex].length) {
                    currentLine.innerHTML += commands[commandIndex].charAt(charIndex);
                    charIndex++;
                    const speed = Math.random() * 30 + 10;
                    setTimeout(typeWriter, speed);
                } else {
                    commandIndex++;
                    charIndex = 0;
                    terminalContent.scrollTop = terminalContent.scrollHeight;
                    setTimeout(typeWriter, 600);
                }
            } else {
                setTimeout(() => {
                    terminalContent.innerHTML += "<p class='text-6xl text-white bg-red-600 inline-block p-2 mt-4 blink'>SYSTEM LOCKDOWN ACTIVE</p>";
                    document.body.style.cursor = 'none';
                    laser.style.left = '50%';
                    laser.style.top = '50%';
                    laser.style.transform = 'translate(-50%, -50%) scale(10)';
                }, 1000);
            }
        }

        setTimeout(typeWriter, 1000);
    </script>
</body>
</html>