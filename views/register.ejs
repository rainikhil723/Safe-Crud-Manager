<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;900&display=swap');
        
        body { 
            font-family: 'Space Grotesk', sans-serif; 
        }
        
        /* Custom Neobrutalist Background Pattern */
        .dotted-bg {
            background-image: radial-gradient(#000 2px, transparent 2px);
            background-size: 24px 24px;
            background-color: #f8f8f8;
        }

        /* Hollow text effect */
        .text-stroke {
            -webkit-text-stroke: 2px black;
            color: transparent;
        }
    </style>
    <title>New Identity | UNLEASHED</title>
</head>
<body class="dotted-bg text-black min-h-screen flex items-center justify-center p-8 pt-24 antialiased selection:bg-green-500 selection:text-white overflow-x-hidden relative">

    <div class="fixed top-0 left-0 w-full overflow-hidden bg-black text-green-400 py-2 z-50 border-b-4 border-black">
        <div class="whitespace-nowrap animate-[marquee_15s_linear_infinite] font-bold tracking-[0.2em] uppercase text-xs flex gap-4">
            <span>/// IDENTITY INITIATION /// NEW USER REGISTRATION ///</span>
            <span>/// IDENTITY INITIATION /// NEW USER REGISTRATION ///</span>
            <span>/// IDENTITY INITIATION /// NEW USER REGISTRATION ///</span>
            <span>/// IDENTITY INITIATION ///</span>
        </div>
    </div>

    <div class="relative w-full max-w-lg group mt-8">
        
        <div class="absolute inset-0 bg-green-400 translate-x-4 translate-y-4 border-4 border-black hidden sm:block transition-transform duration-300 group-hover:translate-x-6 group-hover:translate-y-6"></div>
        
        <div class="relative bg-white border-4 border-black p-8 sm:p-12 shadow-[12px_12px_0_0_#000] hover:shadow-[16px_16px_0_0_#000] hover:-translate-y-2 hover:-translate-x-2 transition-all duration-300 z-10">
            
            <div class="absolute -top-6 -right-6 bg-blue-600 text-white border-4 border-black w-16 h-16 rounded-full flex items-center justify-center font-black text-3xl shadow-[4px_4px_0_0_#000] animate-[spin_10s_linear_infinite] z-20">
                +
            </div>

            <div class="mb-10">
                <div class="inline-block bg-black text-white px-3 py-1 font-bold text-xs tracking-widest uppercase mb-4 transform -rotate-2 border-2 border-black">
                    Clearance Level 1
                </div>
                <h1 class="text-6xl sm:text-7xl font-black uppercase tracking-tighter leading-none text-stroke">Init<br><span class="text-black">Identity</span></h1>
            </div>
            
            <form action="/register" method="POST" class="space-y-8 flex flex-col">
                
                <div class="group/input relative">
                    <label class="absolute -top-3 left-3 bg-white px-2 font-black uppercase text-xs tracking-widest z-10 border-2 border-black group-focus-within/input:bg-green-400 group-focus-within/input:text-black transition-colors">Assign Email</label>
                    <input type="email" name="email" placeholder="NEW@SYSTEM.COM" required class="w-full border-4 border-black bg-gray-50 p-4 font-bold focus:outline-none focus:bg-green-50 focus:border-black focus:shadow-[4px_4px_0_0_#000] focus:-translate-y-1 focus:-translate-x-1 transition-all uppercase placeholder-gray-300 text-lg">
                </div>
                
                <div class="group/input relative">
                    <label class="absolute -top-3 left-3 bg-white px-2 font-black uppercase text-xs tracking-widest z-10 border-2 border-black group-focus-within/input:bg-green-400 group-focus-within/input:text-black transition-colors">Set Password</label>
                    <input type="password" name="password" placeholder="••••••••" required class="w-full border-4 border-black bg-gray-50 p-4 font-bold focus:outline-none focus:bg-green-50 focus:border-black focus:shadow-[4px_4px_0_0_#000] focus:-translate-y-1 focus:-translate-x-1 transition-all uppercase placeholder-gray-300 text-lg">
                </div>
                
                <button type="submit" class="w-full bg-green-400 text-black font-black uppercase tracking-widest p-5 border-4 border-black shadow-[6px_6px_0_0_#000] hover:bg-black hover:text-green-400 hover:shadow-[10px_10px_0_0_#000] hover:-translate-y-2 hover:-translate-x-2 active:translate-y-2 active:translate-x-2 active:shadow-none transition-all cursor-pointer mt-4 flex justify-between items-center group/btn">
                    <span class="text-xl">Initialize</span>
                    <svg class="w-8 h-8 transform group-hover/btn:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="4" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </button>
            </form>

            <div class="mt-10 pt-8 border-t-4 border-black text-center relative">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white px-4 flex gap-1">
                    <div class="w-1 h-4 bg-black"></div>
                    <div class="w-2 h-4 bg-black"></div>
                    <div class="w-1 h-4 bg-black"></div>
                    <div class="w-3 h-4 bg-black"></div>
                    <div class="w-1 h-4 bg-black"></div>
                </div>

                <p class="font-bold uppercase tracking-tight text-gray-500 text-sm">Entity already registered in matrix?</p>
                <a href="/login" class="inline-block mt-3 bg-black text-white font-black uppercase tracking-widest px-6 py-2 border-2 border-black hover:bg-white hover:text-black hover:-translate-y-1 shadow-[4px_4px_0_0_#000] active:translate-y-1 active:shadow-none transition-all">
                    Access Portal
                </a>
            </div>
        </div>
    </div>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    keyframes: {
                        marquee: {
                            '0%': { transform: 'translateX(0%)' },
                            '100%': { transform: 'translateX(-50%)' },
                        }
                    }
                }
            }
        }
    </script>
</body>
</html>