<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Register</title>
</head>
<body>
    <div class="w-full h-screen bg-gradient-to-br from-zinc-900 to-zinc-800 flex items-center justify-center">
        <div class="bg-zinc-800 p-10 rounded-lg shadow-xl w-96">
            <h1 class="text-3xl font-bold text-white mb-8 text-center">Register</h1>
            <form action="/register" method="POST" class="space-y-4">
                <div>
                    <label class="text-white block mb-2">Email</label>
                    <input type="email" name="email" placeholder="Enter your email" required class="w-full px-4 py-2 bg-zinc-700 text-white rounded-lg border border-zinc-600 focus:border-blue-500 outline-none">
                </div>
                <div>
                    <label class="text-white block mb-2">Password</label>
                    <input type="password" name="password" placeholder="Enter your password" required class="w-full px-4 py-2 bg-zinc-700 text-white rounded-lg border border-zinc-600 focus:border-blue-500 outline-none">
                </div>
                <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 rounded-lg mt-6">Register</button>
            </form>
            <p class="text-center text-zinc-400 mt-6">Already have an account? <a href="/login" class="text-blue-500 hover:underline">Login here</a></p>
        </div>
    </div>
</body>
</html>
