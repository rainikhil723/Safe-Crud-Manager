<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>User Details</title>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <div class="flex justify-between items-center mb-8">
            <a class="text-blue-500" href="/read">Back to Users</a>
            <a class="text-red-500 hover:text-red-400" href="/logout">Logout</a>
        </div>

        <h1 class="text-3xl mb-6">User Details</h1>

        <div class="bg-zinc-800 p-6 rounded-lg mb-8">
            <img class="w-48 h-48 object-cover rounded-lg mb-4" src="<%= user.image %>" alt="User image">
            <h2 class="text-2xl"><%= user.name %></h2>
            <p class="text-zinc-400"><%= user.email %></p>
        </div>

        <div class="bg-zinc-800 p-6 rounded-lg mb-8">
            <h3 class="text-xl mb-4">Update User (Edit)</h3>
            <form action="/user/<%= user._id %>/update" method="POST" class="space-y-3">
                <input type="hidden" name="userAccessToken" value="<%= userAccessToken %>">
                <input class="w-full px-4 py-2 bg-zinc-700 border border-zinc-600 rounded-lg" type="text" name="name" value="<%= user.name %>" required>
                <input class="w-full px-4 py-2 bg-zinc-700 border border-zinc-600 rounded-lg" type="email" name="email" value="<%= user.email %>" required>
                <input class="w-full px-4 py-2 bg-zinc-700 border border-zinc-600 rounded-lg" type="text" name="image" value="<%= user.image %>" required>
                <input class="w-full px-4 py-2 bg-zinc-700 border border-zinc-600 rounded-lg" type="password" name="password" placeholder="Set new password (optional)">
                <button class="px-4 py-2 bg-yellow-500 text-black rounded-lg" type="submit">Update User</button>
            </form>
        </div>

        <div class="bg-zinc-800 p-6 rounded-lg mb-8">
            <h3 class="text-xl mb-4">Upload File</h3>
            <form action="/user/<%= user._id %>/upload" method="POST" enctype="multipart/form-data" class="space-y-3">
                <input type="hidden" name="userAccessToken" value="<%= userAccessToken %>">
                <input class="w-full px-4 py-2 bg-zinc-700 border border-zinc-600 rounded-lg" type="file" name="userFile" required>
                <button class="px-4 py-2 bg-green-600 rounded-lg" type="submit">Upload File</button>
            </form>
        </div>

        <a class="inline-block px-4 py-2 bg-blue-600 rounded-lg" href="/user/<%= user._id %>/files?userAccessToken=<%= encodeURIComponent(userAccessToken) %>">Show All Files</a>
    </div>
</body>
</html>
