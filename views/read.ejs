<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>ProjectN</title>
</head>
<body>
<div class="w-full h-full bg-zinc-900 p-10 text-white">
    <div class="flex justify-between items-center mb-5">
        <a class="text-blue-500" href="/">back to home</a>
        <a class="text-red-500 hover:text-red-400" href="/logout">Logout</a>
    </div>
    <h1 class="text-3xl tracking-tighter mb-5 mt-10">All User</h1>
    <div class="users flex gap-5 flex-wrap">
        <% if( users.length > 0) { %>
            <% users.forEach(user => { %>
            <div class="user w-80 p-4 bg-zinc-800 rounded-lg">
                <h3 class="text-xl mt-3 tracking-tighter"><%= user.name %></h3>
                <p class="text-zinc-400 mt-2">Enter this user's password to open details.</p>
                <form class="mt-4" action="/user/<%= user._id %>/open" method="POST">
                    <input
                        class="w-full px-4 py-2 bg-zinc-700 border border-zinc-600 rounded-lg"
                        type="password"
                        name="password"
                        placeholder="Enter user password"
                        required
                    >
                    <button class="mt-3 px-4 py-2 bg-blue-600 rounded-lg" type="submit">Open User</button>
                </form>
            </div>
            <% }); %>
   
        <% } else { %>
            <h1 class="text-zinc-500 tracking-tighter">No Users Found</h1>
        <% } %>
        
    </div>
</body>
</html>