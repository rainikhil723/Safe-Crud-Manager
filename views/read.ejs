<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;900&display=swap');
        
        body { 
            font-family: 'Space Grotesk', sans-serif; 
        }
        
        /* Custom Neobrutalist Background Pattern */
        .dotted-bg {
            background-image: radial-gradient(#000 2px, transparent 2px);
            background-size: 24px 24px;
            background-color: #f8f8f8;
        }

        /* Hollow text effect */
        .text-stroke {
            -webkit-text-stroke: 3px black;
            color: transparent;
        }
    </style>
    <title>Users | SYSTEM DIRECTORY</title>
</head>
<body class="dotted-bg text-black min-h-screen p-8 md:p-16 pt-24 antialiased selection:bg-pink-500 selection:text-white flex flex-col items-center overflow-x-hidden">

    <!-- Decorative Top Marquee Banner -->
    <div class="fixed top-0 left-0 w-full overflow-hidden bg-black text-blue-400 py-2 z-50 border-b-4 border-black">
        <div class="whitespace-nowrap animate-[marquee_15s_linear_infinite] font-bold tracking-[0.2em] uppercase text-xs flex gap-4">
            <span>/// SYSTEM DIRECTORY /// RESTRICTED ACCESS AREA</span>
            <span>/// AUTHORIZED PERSONNEL ONLY</span>
            <span>/// SYSTEM DIRECTORY /// RESTRICTED ACCESS AREA</span>
            <span>/// AUTHORIZED PERSONNEL ONLY ///</span>
        </div>
    </div>

    <!-- Main Container -->
    <div class="w-full max-w-7xl mx-auto relative z-10">
        
        <!-- Navigation -->
        <nav class="flex flex-col md:flex-row justify-between items-start md:items-end border-b-8 border-black pb-8 mb-16 relative group">
            <h1 class="text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none relative z-10">
                <span class="block text-stroke group-hover:text-black transition-colors duration-500">System</span>
                <span class="bg-pink-500 text-white px-4 py-1 inline-block transform -rotate-2 group-hover:rotate-0 transition-transform duration-300 shadow-[8px_8px_0_0_#000]">Directory</span>
            </h1>
            
            <div class="flex gap-6 font-bold uppercase tracking-widest text-sm mt-8 md:mt-0 bg-yellow-300 p-4 border-4 border-black shadow-[6px_6px_0_0_#000]">
                <a href="/" class="hover:text-blue-600 hover:-translate-y-1 transition-transform inline-block">Create New</a>
                <a href="/logout" class="text-red-600 hover:text-black hover:-translate-y-1 transition-transform inline-block">Logout</a>
            </div>
        </nav>

        <!-- Dynamic Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 md:gap-12">
            <% if( users.length > 0) { %>
                <% users.forEach(user => { %>
                    <!-- Kinetic Card Wrapper -->
                    <div class="relative group h-full">
                        
                        <!-- Reactive Pink Shadow Backdrop -->
                        <div class="absolute inset-0 bg-pink-500 translate-x-3 translate-y-3 border-4 border-black hidden md:block transition-transform duration-300 group-hover:translate-x-5 group-hover:translate-y-5"></div>
                        
                        <!-- Main Card -->
                        <div class="relative border-4 border-black p-8 bg-white transition-all hover:-translate-y-2 hover:-translate-x-2 duration-300 z-10 shadow-[12px_12px_0_0_#000] flex flex-col h-full justify-between">
                            
                            <!-- Floating Circular Sticker -->
                            <div class="absolute -top-5 -right-5 bg-blue-500 border-4 border-black w-12 h-12 rounded-full flex items-center justify-center text-white font-black text-xl shadow-[4px_4px_0_0_#000] z-20 transform group-hover:rotate-12 transition-transform">
                                ⌘
                            </div>

                            <div class="mb-8">
                                <div class="inline-block bg-black text-yellow-300 px-3 py-1 font-bold text-xs tracking-widest uppercase mb-4 transform -rotate-1 border-2 border-black">
                                    Target Identified
                                </div>
                                <h3 class="text-4xl font-black uppercase tracking-tighter break-words mb-4 leading-none"><%= user.name %></h3>
                                <p class="text-black font-bold text-sm bg-gray-100 p-3 border-l-4 border-blue-600">ENTER PASSWORD TO ACCESS SECURE VAULT.</p>
                            </div>
                            
                            <form action="/user/<%= user._id %>/open" method="POST" class="mt-auto relative z-20 space-y-6">
                                <!-- Input Group -->
                                <div class="group/input relative">
                                    <label class="absolute -top-3 left-3 bg-white px-2 font-black uppercase text-xs tracking-widest z-10 border-2 border-black group-focus-within/input:bg-blue-600 group-focus-within/input:text-white transition-colors">Access Key</label>
                                    <input class="w-full border-4 border-black bg-gray-50 p-4 font-bold focus:outline-none focus:bg-yellow-100 focus:shadow-[4px_4px_0_0_#000] focus:-translate-y-1 focus:-translate-x-1 transition-all uppercase placeholder-gray-300" type="password" name="password" placeholder="••••••••" required>
                                </div>
                                
                                <!-- Submit Button -->
                                <button class="w-full bg-black text-white font-black uppercase tracking-widest p-4 border-4 border-black shadow-[6px_6px_0_0_#000] hover:bg-yellow-400 hover:text-black hover:shadow-[8px_8px_0_0_#000] hover:-translate-y-1 hover:-translate-x-1 active:translate-y-2 active:translate-x-2 active:shadow-none transition-all cursor-pointer flex justify-between items-center group/btn" type="submit">
                                    <span>Unlock</span>
                                    <svg class="w-6 h-6 transform group-hover/btn:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="4" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                </button>
                            </form>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <!-- Empty State / Error Block -->
                <div class="col-span-full relative group mt-8">
                    <!-- Hazard Backdrop -->
                    <div class="absolute inset-0 bg-red-600 translate-x-4 translate-y-4 border-4 border-black"></div>
                    <div class="relative border-4 border-black p-16 text-center bg-white shadow-[12px_12px_0_0_#000] hover:-translate-y-2 hover:-translate-x-2 transition-all">
                        <div class="text-8xl mb-6">⚠️</div>
                        <h2 class="text-5xl md:text-6xl font-black uppercase tracking-tighter text-red-600 mb-4 text-stroke">System Empty</h2>
                        <p class="text-xl font-bold uppercase tracking-widest bg-black text-white inline-block px-4 py-2 transform rotate-1">No personnel records found.</p>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Tailwind Config for the Marquee Animation -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    keyframes: {
                        marquee: {
                            '0%': { transform: 'translateX(0%)' },
                            '100%': { transform: 'translateX(-50%)' },
                        }
                    }
                }
            }
        }
    </script>
</body>
</html>