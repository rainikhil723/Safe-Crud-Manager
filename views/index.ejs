<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>ProjectN</title>
</head>
<body>
    <div class="w-full h-full bg-zinc-900 p-10 text-white">
        <div class="nav mb-10 flex justify-between items-center">
            <a class="text-blue-500" href="/read">Read Users</a>
            <a class="text-red-500 hover:text-red-400" href="/logout">Logout</a>
        </div>
        <h1 class="text-3xl tracking-tighter mb-5 ">Create User</h1>
        <form action="/create" method="POST" >
                <input class=" px-5 py-2 bg-transparent border-2 border-zinc-800 rounded-lg" outline="none" type="text" name="name" placeholder="Enter your name">
                <input class=" px-5 py-2 bg-transparent border-2 border-zinc-800 rounded-lg" outline="none" type="email" name="email" placeholder="Enter your email">
                <input class=" px-5 py-2 bg-transparent border-2 border-zinc-800 rounded-lg" outline="none" type="text" name="image" placeholder="Enter image url">
            <input class=" px-5 py-2 bg-transparent border-2 border-zinc-800 rounded-lg" outline="none" type="password" name="password" placeholder="Set user password" required>
                <input class="px-5 py-2 bg-blue-500 rounded-lg ml-3" type="submit" value="Create User">
        </form>
    </div>
</body>
</html>