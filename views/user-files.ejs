<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;900&display=swap');
        
        body { 
            font-family: 'Space Grotesk', sans-serif; 
        }
        
        /* Custom Neobrutalist Background Pattern */
        .dotted-bg {
            background-image: radial-gradient(#000 2px, transparent 2px);
            background-size: 24px 24px;
            background-color: #f8f8f8;
        }

        /* Hollow text effect */
        .text-stroke {
            -webkit-text-stroke: 3px black;
            color: transparent;
        }
    </style>
    <title>Storage Matrix | UNLEASHED</title>
</head>
<body class="dotted-bg text-black min-h-screen p-8 md:p-16 pt-24 antialiased selection:bg-green-400 selection:text-black flex flex-col items-center overflow-x-hidden">

    <div class="fixed top-0 left-0 w-full overflow-hidden bg-black text-green-400 py-2 z-50 border-b-4 border-black">
        <div class="whitespace-nowrap animate-[marquee_15s_linear_infinite] font-bold tracking-[0.2em] uppercase text-xs flex gap-4">
            <span>/// STORAGE MATRIX /// ENCRYPTED FILE SYSTEM /// SECURE REPOSITORY ///</span>
            <span>/// STORAGE MATRIX /// ENCRYPTED FILE SYSTEM /// SECURE REPOSITORY ///</span>
            <span>/// STORAGE MATRIX /// ENCRYPTED FILE SYSTEM /// SECURE REPOSITORY ///</span>
        </div>
    </div>

    <div class="w-full max-w-6xl mx-auto relative z-10">
        
        <nav class="flex flex-col md:flex-row justify-between items-start md:items-end border-b-8 border-black pb-8 mb-12 relative group">
            <h1 class="text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none relative z-10">
                <span class="block text-stroke group-hover:text-black transition-colors duration-500">Storage</span>
                <span class="bg-green-400 text-black px-4 py-1 inline-block transform -rotate-2 group-hover:rotate-0 transition-transform duration-300 shadow-[8px_8px_0_0_#000]">Matrix</span>
            </h1>
            
            <div class="flex gap-6 font-bold uppercase tracking-widest text-sm mt-8 md:mt-0 bg-yellow-300 p-4 border-4 border-black shadow-[6px_6px_0_0_#000]">
                <a class="hover:text-blue-600 hover:-translate-y-1 transition-transform inline-block" href="/user/<%= user._id %>?userAccessToken=<%= encodeURIComponent(userAccessToken) %>">Return</a>
                <a class="text-red-600 hover:text-black hover:-translate-y-1 transition-transform inline-block" href="/logout">Logout</a>
            </div>
        </nav>

        <div class="mb-12 inline-flex items-center gap-4 bg-black p-4 border-4 border-black shadow-[8px_8px_0_0_#000] transform -rotate-1 hover:rotate-0 transition-transform">
            <span class="bg-yellow-400 text-black font-black uppercase tracking-widest text-sm px-3 py-1">Target ID</span>
            <h2 class="text-3xl font-black uppercase tracking-tighter text-white truncate"><%= user.name %></h2>
        </div>

        <% if (user.files && user.files.length > 0) { %>
            <div class="space-y-8">
                <% user.files.forEach(file => { %>
                    
                    <div class="relative group/file">
                        
                        <div class="absolute inset-0 bg-blue-500 translate-x-3 translate-y-3 border-4 border-black hidden md:block transition-transform duration-300 group-hover/file:translate-x-5 group-hover/file:translate-y-5"></div>
                        
                        <div class="relative border-4 border-black p-6 md:p-8 bg-white flex flex-col md:flex-row md:justify-between md:items-center gap-8 transition-all hover:-translate-y-2 hover:-translate-x-2 duration-300 z-10 shadow-[12px_12px_0_0_#000] hover:shadow-[16px_16px_0_0_#000]">
                            
                            <div class="absolute -top-5 -left-5 bg-pink-500 border-4 border-black w-12 h-12 flex items-center justify-center font-black text-2xl shadow-[4px_4px_0_0_#000] transform -rotate-12 z-20 group-hover/file:rotate-12 transition-transform">
                                📁
                            </div>

                            <div class="overflow-hidden flex-1 pl-6 md:pl-8">
                                <p class="font-black text-3xl md:text-4xl truncate uppercase tracking-tight mb-4 group-hover/file:text-blue-600 transition-colors"><%= file.originalName %></p>
                                
                                <div class="flex flex-wrap gap-3 font-bold text-xs uppercase tracking-widest">
                                    <span class="bg-gray-100 border-2 border-black px-3 py-1 shadow-[2px_2px_0_0_#000]">
                                        TYPE: <%= file.mimetype %>
                                    </span>
                                    <span class="bg-yellow-100 border-2 border-black px-3 py-1 shadow-[2px_2px_0_0_#000]">
                                        SIZE: <%= Math.ceil(file.size / 1024) %> KB
                                    </span>
                                </div>
                            </div>
                            
                            <div class="flex flex-col sm:flex-row gap-4 shrink-0">
                                <a class="bg-green-400 text-black font-black uppercase tracking-widest px-8 py-4 border-4 border-black hover:bg-black hover:text-green-400 transition-all text-center shadow-[6px_6px_0_0_#000] hover:shadow-[8px_8px_0_0_#000] hover:-translate-y-1 hover:-translate-x-1 active:translate-y-2 active:translate-x-2 active:shadow-none" href="/user/<%= user._id %>/file/<%= file._id %>?userAccessToken=<%= encodeURIComponent(userAccessToken) %>" target="_blank">
                                    Extract
                                </a>
                                
                                <form action="/user/<%= user._id %>/file/<%= file._id %>/delete?userAccessToken=<%= encodeURIComponent(userAccessToken) %>" method="POST" onsubmit="return confirm('WARNING: UNRECOVERABLE PURGE. PROCEED?');" class="flex-1 sm:flex-none">
                                    <button type="submit" class="w-full bg-red-600 text-white font-black uppercase tracking-widest px-8 py-4 border-4 border-black hover:bg-black transition-all cursor-pointer text-center shadow-[6px_6px_0_0_#000] hover:shadow-[8px_8px_0_0_#000] hover:-translate-y-1 hover:-translate-x-1 active:translate-y-2 active:translate-x-2 active:shadow-none">
                                        Purge
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            
            <div class="relative group mt-12">
                <div class="absolute inset-0 bg-yellow-400 translate-x-4 translate-y-4 border-4 border-black"></div>
                <div class="relative border-4 border-black p-16 md:p-24 bg-white shadow-[12px_12px_0_0_#000] flex flex-col items-center text-center hover:-translate-y-2 hover:-translate-x-2 transition-all">
                    
                    <div class="text-8xl mb-8 transform -rotate-12 group-hover:rotate-12 transition-transform duration-500">📭</div>
                    <h3 class="text-5xl md:text-7xl font-black uppercase tracking-tighter text-stroke text-black mb-6">Matrix Empty</h3>
                    
                    <div class="bg-black text-yellow-400 font-bold uppercase tracking-widest px-6 py-3 border-4 border-black transform rotate-2">
                        NO DATA BLOCKS FOUND FOR THIS IDENTITY.
                    </div>
                    
                </div>
            </div>
            
        <% } %>
    </div>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    keyframes: {
                        marquee: {
                            '0%': { transform: 'translateX(0%)' },
                            '100%': { transform: 'translateX(-50%)' },
                        }
                    }
                }
            }
        }
    </script>
</body>
</html>