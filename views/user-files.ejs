<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>User Files</title>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <div class="flex justify-between items-center mb-8">
            <a class="text-blue-500" href="/user/<%= user._id %>?userAccessToken=<%= encodeURIComponent(userAccessToken) %>">Back to User Details</a>
            <a class="text-red-500 hover:text-red-400" href="/logout">Logout</a>
        </div>

        <h1 class="text-3xl mb-6">Files for <%= user.name %></h1>

        <% if (user.files && user.files.length > 0) { %>
            <div class="space-y-3">
                <% user.files.forEach(file => { %>
                    <div class="bg-zinc-800 p-4 rounded-lg flex justify-between items-center">
                        <div>
                            <p class="font-semibold"><%= file.originalName %></p>
                            <p class="text-sm text-zinc-400"><%= file.mimetype %> | <%= Math.ceil(file.size / 1024) %> KB</p>
                        </div>
                        <a class="px-3 py-1 bg-blue-600 rounded-lg" href="<%= file.path %>" target="_blank">Open</a>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <p class="text-zinc-400">No files uploaded yet.</p>
        <% } %>
    </div>
</body>
</html>
